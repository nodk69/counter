# ─── Site ────────────────────────────────────────────────────────────────────
# Public URL of your deployed site (no trailing slash).
# Used to build canonical, og:url, and sitemap URLs.
VITE_SITE_URL=https://counter.io

# ─── SEO / Search Console ────────────────────────────────────────────────────
# Google Search Console ownership verification code.
# Paste the value from the HTML-tag verification method.
# e.g. VITE_GOOGLE_SITE_VERIFICATION=abc123XYZ
VITE_GOOGLE_SITE_VERIFICATION=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_ID=

# Microsoft Clarity project ID
VITE_CLARITY_ID=

# ─── Dev server ──────────────────────────────────────────────────────────────
# Port the Vite dev server listens on. Defaults to 5173.
PORT=5173

# Base path if the app is served from a subdirectory (e.g. /app/).
# Leave as / for root deployment.
BASE_PATH=/
